    },
    {
      "stepType": "TEXT",
      "step": "Press directional buttons repeatedly",
      "data": "UP, DOWN, LEFT, RIGHT",
      "expectedResult": "System responds without noticeable delay or missed inputs"
    },
    {
      "stepType": "TEXT",
      "step": "Press LEFT on directional pad",
      "data": "",
      "expectedResult": "Hamburger menu opens"
    },
    {
      "stepType": "TEXT",
      "step": "Press RIGHT on directional pad",
      "data": "",
      "expectedResult": "Focus returns to main content area"
    },
    {
      "stepType": "TEXT",
      "step": "Press UP on directional pad",
      "data": "",
      "expectedResult": "Focus moves up"
    },
    {
      "stepType": "TEXT",
      "step": "Press DOWN on directional pad",
      "data": "",
      "expectedResult": "Focus moves down"
    },
    {
      "stepType": "TEXT",
      "step": "Press OK button",
